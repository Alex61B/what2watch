{
  "permissions": {
    "allow": [
      "Agent(*)",
      "Bash(pwd)",
      "Bash(pwd *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(ls -la *)",
      "Bash(find *)",
      "Bash(tree *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git diff --stat)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git log --oneline)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run test)",
      "Bash(npm run test *)",
      "Bash(npm run build)",
      "Bash(npm run build *)",
      "Bash(npm run lint)",
      "Bash(npm run lint *)",
      "Bash(npm run typecheck)",
      "Bash(npm run typecheck *)",
      "Bash(bash scripts/*)",
      "Bash(bash scripts/* *)",
      "Bash(bash .claude/hooks/*)",
      "Bash(mkdir *)",
      "Bash(chmod *)",
      "Bash(rm *)",
      "Bash(echo *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Write(*)",
      "Edit(*)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma validate*)",
      "Bash(npx prisma format*)",
      "Bash(npx prisma migrate status*)"
    ],
    "ask": [
      "Bash(npx prisma migrate deploy*)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma db push*)",
      "Bash(npx prisma migrate reset*)",
      "mcp__vercel__deploy_to_vercel",
      "mcp__vercel__add_toolbar_reaction",
      "mcp__vercel__change_toolbar_thread_resolve_status",
      "mcp__vercel__edit_toolbar_message",
      "mcp__vercel__reply_to_toolbar_thread",
      "mcp__vercel__import-claude-design-from-url",
      "mcp__vercel__get_access_to_vercel_url"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre_tool_use.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_tool_use.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop.sh"
          }
        ]
      }
    ]
  }
}
